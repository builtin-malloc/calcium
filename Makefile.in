###############################################################################
#                                    PATHS                                    #
###############################################################################

LIBSRC := $(wildcard @SRCDIR@/*.c)
LIBOBJ := $(LIBSRC:@SRCDIR@/%.c=@OBJDIR@/%.o)
LIBDEP := $(LIBOBJ:.o=.d)
LIB    := @BINDIR@/libcalcium.a

BINSRC := $(wildcard @APPDIR@/*.c)
BINOBJ := $(BINSRC:@APPDIR@/%.c=@OBJDIR@/%.o)
BINDEP := $(BINOBJ:.o=.d)
BIN    := @BINDIR@/calcium

###############################################################################
#                                   TARGETS                                   #
###############################################################################

# BUILD #######################################################################

.PHONY: build

build: $(BIN)

$(BIN): $(BINOBJ) $(LIB)
	@CCLD@ -o $@ $(filter %.o,$^) @LDFLAGS@  -lcalcium
$(LIB): $(LIBOBJ)
	@AR@ @ARFLAGS@ $@ $(filter %.o,$^)

$(BINOBJ): @OBJDIR@/%.o: @APPDIR@/%.c
	@CC@ -o $@ -c $< @CFLAGS@
$(LIBOBJ): @OBJDIR@/%.o: @SRCDIR@/%.c
	@CC@ -o $@ -c $< @CFLAGS@

-include $(LIBDEP)
-include $(BINDEP)

# CLEAN #######################################################################

.PHONY: clean distclean

clean:
	rm -f $(BIN)
	rm -f $(BINOBJ)
	rm -f $(BINDEP)
	rm -f $(LIB)
	rm -f $(LIBOBJ)
	rm -f $(LIBDEP)

distclean:
	rm -rf @BINDIR@
	rm -rf @BINDIR@

# CONFIGURE ###################################################################

%: Makefile
Makefile: Makefile.in configure
	./configure

